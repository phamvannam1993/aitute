{
    "name": "laravel/laravel",
    "type": "project",
    "description": "The skeleton application for the Laravel framework.",
    "keywords": ["laravel", "framework"],
    "license": "MIT",
    "require": {
        "php": "^8.2",
        "ahmadrosid/anthropic-php": "^1.0",
        "aws/aws-sdk-php": "^3.322",
        "creatomate/creatomate": "*",
        "devdojo/google-image-search": "*",
        "google/apiclient": "^2.0",
        "guzzlehttp/guzzle": "^7.9",
        "inertiajs/inertia-laravel": "^1.0",
        "james-heinrich/getid3": "^1.9",
        "jenssegers/agent": "^2.6",
        "joelbutcher/facebook-graph-sdk": "^6.0",
        "laravel/framework": "^11.9",
        "laravel/sanctum": "^4.0",
        "laravel/socialite": "^5.16",
        "laravel/tinker": "^2.9",
        "league/flysystem-aws-s3-v3": "^3.0",
        "maatwebsite/excel": "^3.1",
        "mavinoo/laravel-batch": "^2.4",
        "modelflow-ai/anthropic": "^0.2.0",
        "openai-php/client": "^0.10.1",
        "openai-php/laravel": "^0.10.2",
        "php-ffmpeg/php-ffmpeg": "^1.2",
        "php-http/guzzle7-adapter": "^1.0",
        "phpoffice/phpword": "^1.3",
        "psr/http-message": "^1.0",
        "setasign/fpdf": "^1.8",
        "setasign/fpdi": "^2.6",
        "spatie/async": "^1.6",
        "spatie/laravel-activitylog": "^4.9",
        "spatie/laravel-permission": "^6.10",
        "spatie/pdf-to-text": "^1.53",
        "tightenco/ziggy": "^2.0",
        "zaloplatform/zalo-php-sdk": "^4.0",
        "ext-dom": "*"
    },
    "require-dev": {
        "fakerphp/faker": "^1.23",
        "laravel/breeze": "^2.2",
        "laravel/pint": "^1.13",
        "laravel/sail": "^1.26",
        "mockery/mockery": "^1.6",
        "nunomaduro/collision": "^8.0",
        "phpunit/phpunit": "^11.0.1"
    },
    "autoload": {
        "files": [
            "app/Helper/Youtube.php"
        ],
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi"
        ],
        "post-update-cmd": [
            "@php artisan vendor:publish --tag=laravel-assets --ansi --force"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi",
            "@php -r \"file_exists('database/database.sqlite') || touch('database/database.sqlite');\"",
            "@php artisan migrate --graceful --ansi"
        ]
    },
    "extra": {
        "laravel": {
            "dont-discover": []
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
